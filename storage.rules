rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Tile media uploads: Only authenticated users can upload, with size limits
    match /tiles/{fileName} {
      // Anyone can read (needed to display tile images)
      allow read: if true;

      // Only authenticated users can upload
      // Images: max 5MB, Videos: max 50MB
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('video/.*')
                   );
    }

    // Premium billboard media uploads: same rules
    match /premium_media/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('image/.*')
                     || request.resource.contentType.matches('video/.*')
                   );
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
