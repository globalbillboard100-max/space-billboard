# ── Frontend (Vite) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Razorpay (used in frontend checkout) ──
VITE_RAZORPAY_KEY_ID=

# ── Backend (Vercel Serverless Functions) ──
# Paste your Firebase Service Account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT=
# Your Razorpay Key Secret (server-side only, never expose to frontend)
RAZORPAY_SECRET=

# ── Legacy / Media Config (optional) ──
VITE_TEXTURES_BASE_URL=/media
VITE_FILM_INFO_BASE_URL=/json
VITE_MEDIA_VERSION_0_LAYERS=1
VITE_MEDIA_VERSION_1_LAYERS=1
VITE_MEDIA_VERSION_2_LAYERS=1
VITE_EXPERIMENTAL_MEDIA_VERSION_3_ENABLED=1
VITE_COMPRESS_GLSL=
VITE_ANALYZE_BUNDLE=