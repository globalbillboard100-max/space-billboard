rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Bookings collection: Only the backend (Admin SDK) can write.
    // Frontend users can read all bookings (needed for real-time sync).
    match /bookings/{tileId} {
      allow read: if true;
      // Allow frontend writes for Dev Mode testing, must be auth'd and marked as testMode
      allow write: if (request.auth != null && request.resource.data.testMode == true) || false; 
    }

    match /premium_bookings/{bookingId} {
      allow read: if true;
      allow write: if (request.auth != null && request.resource.data.testMode == true) || false;
    }

    // Tiles collection (legacy, if still referenced)
    match /tiles/{tileId} {
      allow read: if true;
      allow write: if false;
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
